#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

PREV_HEAD="$1"
NEW_HEAD="$2"
BRANCH_CHECKOUT="$3"

# Only run on branch checkout, not file checkout
[ "$BRANCH_CHECKOUT" -eq 1 ] || exit 0

log "Branch switch detected — rebuilding site…"
require_bin bonfyre-emit || exit 0

if [ -d artifacts ] && [ "$(find artifacts/ -name '*.json' 2>/dev/null | wc -l)" -gt 0 ]; then
  bonfyre-emit artifacts/ --out site/ --format html
  log "Site rebuilt for $(git branch --show-current)."
fi
